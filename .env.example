# =============================================================================
# Wild Apricot Export Scripts - Environment Configuration
# Copy this file to `.env` and fill in your values.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED: Wild Apricot API credentials
# -----------------------------------------------------------------------------

# API key from: Settings -> Authorized applications -> Authorize application
# Used by: all REST API exports (events, contacts, invoices, payments, donations,
#          registrations, audit-log, config)
WILD_APRICOT_API_KEY=

# Optional. If left blank, scripts will auto-discover the first account on the
# API key. Set it explicitly if you have multiple accounts.
WILD_APRICOT_ACCOUNT_ID=


# -----------------------------------------------------------------------------
# REQUIRED FOR FILE EXPORT (export-files.js / `npm run export-files`)
# -----------------------------------------------------------------------------

# Your Wild Apricot WebDAV URL.
# Usually: https://YOURDOMAIN/resources  (e.g. https://example.org/resources)
# You can also use https://YOURACCOUNT.wildapricot.org/resources
WILD_APRICOT_WEBDAV_URL=

# Your Wild Apricot administrator login (NOT the API key).
WILD_APRICOT_ADMIN_EMAIL=
WILD_APRICOT_ADMIN_PASSWORD=

# Comma-separated list of folders to crawl (recursively).
# If left BLANK, the script crawls everything under `/` recursively (including
# any files at the root). Listing `/` may 500 on some Wild Apricot accounts —
# in that case, set this explicitly to scope the crawl. Example:
# WILD_APRICOT_FILE_DIRS=Documents,Pictures,Logos,Theme,Theme_Overrides,SiteUploads,SiteAlbums,EmailTemplates,favicon,Site
WILD_APRICOT_FILE_DIRS=


# -----------------------------------------------------------------------------
# OPTIONAL: Throttling
# -----------------------------------------------------------------------------

# Delay between *event* API calls (export-events.js, retry-event-failures.js).
# Event routes are often capped around 30 requests/minute in practice; default
# 2200ms (~27/min) stays under that. Lower only if Wild Apricot confirms a higher
# limit for your account.
# WA_EVENT_REQUEST_DELAY_MS=2200

# Delay between calls in export-registrations.js (one request per event for
# registrations). Increase if you see 429s. Default: 350
# WA_REQUEST_DELAY_MS=350

# How often (in events) export-registrations.js flushes its resume checkpoint
# to disk. The script is resumable: if it dies partway through, just re-run
# `npm run export-registrations` and it'll skip already-processed events.
# WA_REGISTRATIONS_SAVE_EVERY=5


# -----------------------------------------------------------------------------
# OPTIONAL: Date-range filters for financial exports
# All dates use YYYY-MM-DD format. Leave blank to fetch everything.
# -----------------------------------------------------------------------------

# export-invoices.js
# INVOICES_START_DATE=2020-01-01
# INVOICES_END_DATE=2026-12-31

# export-payments.js
# PAYMENTS_START_DATE=2020-01-01
# PAYMENTS_END_DATE=2026-12-31

# export-donations.js
# DONATIONS_START_DATE=2020-01-01
# DONATIONS_END_DATE=2026-12-31

# export-audit-log.js
# Wild Apricot only retains audit history for a limited window (often 30-90
# days depending on plan), so very old StartDate values will return nothing.
# AUDIT_START_DATE=2026-01-01
# AUDIT_END_DATE=2026-12-31
